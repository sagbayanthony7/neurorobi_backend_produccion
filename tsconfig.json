{
  "compilerOptions": {
    // Output
    "rootDir": "./src",
    "outDir": "./dist",

    // Module / Target
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],

    // Node types
    "types": ["node"],

    // Interop
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    // Strictness (sensible for backend)
    "strict": true,
    "skipLibCheck": true,

    // Source maps
    "sourceMap": true,
    "declaration": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
